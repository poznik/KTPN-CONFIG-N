                                        <ComboBox Grid.Row="1" Grid.Column="3" ItemsSource="{Binding TtAccuracyClasses}" SelectedItem="{Binding CtKipAccuracyClass}" IsEnabled="{Binding HasCtKip}"/>
                                    </Grid>
                                </StackPanel>
                            </materialDesign:Card>
                        </Grid>

                        <Border Background="{StaticResource SurfaceMutedBrush}" BorderBrush="{StaticResource SurfaceBorderBrush}" BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,0,0,12">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <CheckBox Content="Автоподбор номинала ввода и ТТ" IsChecked="{Binding AutoElectricalSelection}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="{Binding AutoSelectionSummary}" TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" Margin="16,0" VerticalAlignment="Center"/>
                                <Button Grid.Column="2" Command="{Binding ApplyElectricalSelectionCommand}" Style="{StaticResource ToolbarFlatButton}" ToolTip="Повторить автоматический подбор">
                                    <materialDesign:PackIcon Kind="Refresh" Width="20" Height="20"/>
                                </Button>
                            </Grid>
                        </Border>

                        <materialDesign:Card Style="{StaticResource GroupCard}">
                            <StackPanel>
                                <TextBlock Text="Отходящие линии РУНН" Style="{StaticResource SectionHeader}" HorizontalAlignment="Center"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="180"/><ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="180"/><ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="190"/><ColumnDefinition Width="220"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                                    <CheckBox Grid.Row="0" Grid.Column="0" Content="Автоматы (АВ)" IsChecked="{Binding AvOn}"/>
                                    <ComboBox Grid.Row="0" Grid.Column="1" Margin="0,2,12,2" ItemsSource="{Binding AvQuantityOptions}" SelectedItem="{Binding AvQty}" IsEnabled="{Binding AvOn}"/>
                                    <CheckBox Grid.Row="0" Grid.Column="2" Content="РПС" IsChecked="{Binding RpsOn}"/>
                                    <ComboBox Grid.Row="0" Grid.Column="3" Margin="0,2,12,2" ItemsSource="{Binding RpsQuantityOptions}" SelectedItem="{Binding RpsQty}" IsEnabled="{Binding RpsOn}"/>
                                    <TextBlock Grid.Row="0" Grid.Column="4" Text="Исполнение вывода:" Style="{StaticResource ColLabel}"/>
                                    <ComboBox Grid.Row="0" Grid.Column="5" ItemsSource="{Binding CableExecutions}" SelectedItem="{Binding OutgoingExecution}"/>
                                    <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="6" Text="{Binding OutgoingFeederCount, StringFormat=Отходящие линии: {0}}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" Margin="0,4,0,8"/>
                                </Grid>

                                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                                    <StackPanel Width="1600">
                                        <Grid Margin="8,0,8,5">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="42"/><ColumnDefinition Width="62"/><ColumnDefinition Width="70"/><ColumnDefinition Width="190"/><ColumnDefinition Width="62"/>
                                                <ColumnDefinition Width="145"/><ColumnDefinition Width="185"/><ColumnDefinition Width="90"/><ColumnDefinition Width="125"/>
                                                <ColumnDefinition Width="100"/><ColumnDefinition Width="115"/><ColumnDefinition Width="115"/><ColumnDefinition Width="190"/><ColumnDefinition Width="90"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="№" FontWeight="SemiBold"/>
                                            <TextBlock Grid.Column="1" Text="Тип" FontWeight="SemiBold"/>
                                            <TextBlock Grid.Column="2" Text="Секция" FontWeight="SemiBold" Visibility="{Binding ShowDoubleKtpnConfiguration, Converter={StaticResource BoolToVisibility}}"/>
                                            <TextBlock Grid.Column="3" Text="Назначение" FontWeight="SemiBold"/><TextBlock Grid.Column="4" Text="Резерв" FontWeight="SemiBold"/><TextBlock Grid.Column="5" Text="Бренд" FontWeight="SemiBold"/><TextBlock Grid.Column="6" Text="Модель" FontWeight="SemiBold"/><TextBlock Grid.Column="7" Text="Ток, А" FontWeight="SemiBold"/><TextBlock Grid.Column="8" Text="Учет" FontWeight="SemiBold"/><TextBlock Grid.Column="9" Text="ТТ" FontWeight="SemiBold"/><TextBlock Grid.Column="10" Text="Кабель" FontWeight="SemiBold"/><TextBlock Grid.Column="11" Text="Сечение" FontWeight="SemiBold"/><TextBlock Grid.Column="12" Text="Примечание" FontWeight="SemiBold"/>
                                        </Grid>
                                        <ItemsControl ItemsSource="{Binding OutgoingFeeders}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border BorderBrush="{StaticResource SurfaceBorderBrush}" BorderThickness="0,1,0,0" Padding="8,5">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="42"/><ColumnDefinition Width="62"/><ColumnDefinition Width="70"/><ColumnDefinition Width="190"/><ColumnDefinition Width="62"/>
                                                                <ColumnDefinition Width="145"/><ColumnDefinition Width="185"/><ColumnDefinition Width="90"/><ColumnDefinition Width="125"/>
                                                                <ColumnDefinition Width="100"/><ColumnDefinition Width="115"/><ColumnDefinition Width="115"/><ColumnDefinition Width="190"/><ColumnDefinition Width="90"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" Text="{Binding Number}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                            <TextBlock Grid.Column="1" Text="{Binding DeviceType}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                            <ComboBox Grid.Column="2" Margin="2" ItemsSource="{Binding SectionOptions}" SelectedItem="{Binding SectionNumber}" Visibility="{Binding ShowSectionSelector, Converter={StaticResource BoolToVisibility}}"/>
                                                            <TextBox Grid.Column="3" Margin="2" Text="{Binding Purpose, UpdateSourceTrigger=LostFocus}"/><CheckBox Grid.Column="4" IsChecked="{Binding IsReserve}" HorizontalAlignment="Center" VerticalAlignment="Center" ToolTip="Резервная линия"/>
                                                            <ComboBox Grid.Column="5" Margin="2" ItemsSource="{Binding Manufacturers}" SelectedItem="{Binding Manufacturer}" ToolTip="{Binding Manufacturer}"/><ComboBox Grid.Column="6" Margin="2" ItemsSource="{Binding ModelOptions}" SelectedItem="{Binding Model}" ToolTip="{Binding Model}"/>
                                                            <ComboBox Grid.Column="7" Margin="2" ItemsSource="{Binding Nominals}" SelectedItem="{Binding Nominal}" ItemTemplate="{StaticResource AmpereItemTemplate}"/><ComboBox Grid.Column="8" Margin="2" ItemsSource="{Binding MeteringTypes}" SelectedItem="{Binding MeteringType}"/><ComboBox Grid.Column="9" Margin="2" ItemsSource="{Binding TtRatios}" SelectedItem="{Binding TtRatio}" IsEnabled="{Binding HasMeter}"/>
                                                            <TextBox Grid.Column="10" Margin="2" Text="{Binding CableMark, UpdateSourceTrigger=LostFocus}"/><TextBox Grid.Column="11" Margin="2" Text="{Binding CableSection, UpdateSourceTrigger=LostFocus}"/><TextBox Grid.Column="12" Margin="2" Text="{Binding Notes, UpdateSourceTrigger=LostFocus}"/>
                                                            <StackPanel Grid.Column="13" Orientation="Horizontal" HorizontalAlignment="Right">
                                                                <Button Command="{Binding DuplicateCommand}" Width="34" Height="32" Padding="5" Margin="2" ToolTip="Копировать линию" Style="{StaticResource ToolbarFlatButton}">
                                                                    <materialDesign:PackIcon Kind="ContentCopy" Width="18" Height="18"/>
                                                                </Button>
                                                                <Button Command="{Binding DeleteCommand}" Width="34" Height="32" Padding="5" Margin="2" ToolTip="Удалить линию" Style="{StaticResource ToolbarFlatButton}">
                                                                    <materialDesign:PackIcon Kind="DeleteOutline" Width="18" Height="18"/>
                                                                </Button>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </ScrollViewer>
                            </StackPanel>
                        </materialDesign:Card>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ===== TAB 4 ===== -->
            <TabItem Visibility="{Binding ShowKtpnTabs, Converter={StaticResource BoolToVisibility}}">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <Border Width="12" Height="12" CornerRadius="6" Background="{Binding AuxiliaryTabStatusColor, Converter={StaticResource StrBrush}}" BorderBrush="White" BorderThickness="1" Margin="0,0,7,0" ToolTip="{Binding AuxiliaryTabStatusText}"/>
                        <TextBlock Text="5. Собственные нужды" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="6">
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <materialDesign:Card Style="{StaticResource GroupCard}">
                                <StackPanel>
                                    <TextBlock Text="Шкаф собственных нужд" Style="{StaticResource SectionHeader}"/>
                                    <CheckBox Content="Шкаф собственных нужд" IsChecked="{Binding HasAuxiliaryCabinet}"/>
                                    <CheckBox Content="Питание от шин РУНН" IsChecked="{Binding AuxSupplyFromRunn}" Margin="0,4,0,8" IsEnabled="{Binding HasAuxiliaryCabinet}"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="170"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Производитель ЩСН:" Style="{StaticResource ColLabel}"/>
                                        <ComboBox Grid.Row="0" Grid.Column="1" ItemsSource="{Binding AuxCabinetManufacturers}" SelectedItem="{Binding AuxCabinetManufacturer}" IsEnabled="{Binding HasAuxiliaryCabinet}"/>
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Модель ЩСН:" Style="{StaticResource ColLabel}"/>
                                        <ComboBox Grid.Row="1" Grid.Column="1" ItemsSource="{Binding AuxCabinetModels}" SelectedItem="{Binding AuxCabinetModel}" IsEnabled="{Binding HasAuxiliaryCabinet}"/>
                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Автомат ввода:" Style="{StaticResource ColLabel}"/>
                                        <ComboBox Grid.Row="2" Grid.Column="1" ItemsSource="{Binding AuxBreakerManufacturers}" SelectedItem="{Binding AuxMainBreakerManufacturer}" IsEnabled="{Binding HasAuxiliaryCabinet}"/>
                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Модель автомата:" Style="{StaticResource ColLabel}"/>
                                        <ComboBox Grid.Row="3" Grid.Column="1" ItemsSource="{Binding AuxMainBreakerModels}" SelectedItem="{Binding AuxMainBreakerModel}" IsEnabled="{Binding HasAuxiliaryCabinet}"/>
                                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Номинал автомата:" Style="{StaticResource ColLabel}"/>
                                        <ComboBox Grid.Row="4" Grid.Column="1" ItemsSource="{Binding AuxMainBreakerNominals}" SelectedItem="{Binding AuxMainBreakerNominal}" ItemTemplate="{StaticResource AmpereItemTemplate}" IsEnabled="{Binding HasAuxiliaryCabinet}"/>
                                    </Grid>
                                </StackPanel>
                            </materialDesign:Card>

                            <materialDesign:Card Style="{StaticResource GroupCard}" Visibility="{Binding HasAuxiliaryCabinet, Converter={StaticResource BoolToVisibility}}">
                                <StackPanel>
                                    <TextBlock Text="Освещение" Style="{StaticResource SectionHeader}"/>
                                    <CheckBox Content="Освещение КТПН" IsChecked="{Binding HasLighting}" IsEnabled="{Binding HasAuxiliaryCabinet}"/>
                                    <Grid Margin="0,6,0,0">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="170"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Производитель АВ:" Style="{StaticResource ColLabel}"/>
                                        <ComboBox Grid.Row="0" Grid.Column="1" ItemsSource="{Binding AuxBreakerManufacturers}" SelectedItem="{Binding LightingBreakerManufacturer}" IsEnabled="{Binding IsLightingControlEnabled}"/>
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Модель АВ:" Style="{StaticResource ColLabel}"/>
                                        <ComboBox Grid.Row="1" Grid.Column="1" ItemsSource="{Binding LightingBreakerModels}" SelectedItem="{Binding LightingBreakerModel}" IsEnabled="{Binding IsLightingControlEnabled}"/>
                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Номинал АВ:" Style="{StaticResource ColLabel}"/>
                                        <ComboBox Grid.Row="2" Grid.Column="1" ItemsSource="{Binding LightingBreakerNominals}" SelectedItem="{Binding LightingBreakerNominal}" ItemTemplate="{StaticResource AmpereItemTemplate}" IsEnabled="{Binding IsLightingControlEnabled}"/>
                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Цепей освещения:" Style="{StaticResource ColLabel}"/>
                                        <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding LightingCircuits, UpdateSourceTrigger=LostFocus}" IsEnabled="{Binding IsLightingControlEnabled}"/>
                                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Светильник:" Style="{StaticResource ColLabel}"/>
                                        <ComboBox Grid.Row="4" Grid.Column="1" ItemsSource="{Binding LightingFixtureModels}" SelectedItem="{Binding LightingFixtureModel}" IsEnabled="{Binding IsLightingControlEnabled}"/>
                                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Количество светильников:" Style="{StaticResource ColLabel}"/>
                                        <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding LightingFixtureQuantity, UpdateSourceTrigger=LostFocus}" IsEnabled="{Binding IsLightingControlEnabled}"/>
                                        <TextBlock Grid.Row="6" Grid.Column="0" Text="Управление:" Style="{StaticResource ColLabel}"/>
                                        <ComboBox Grid.Row="6" Grid.Column="1" ItemsSource="{Binding LightingControlTypeOptions}" SelectedItem="{Binding LightingControlType}" IsEnabled="{Binding IsLightingControlEnabled}"/>
                                        <TextBlock Grid.Row="7" Grid.Column="0" Text="Отсеки:" Style="{StaticResource ColLabel}"/>
                                        <TextBox Grid.Row="7" Grid.Column="1" Text="{Binding LightingAreas, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsLightingControlEnabled}"/>
                                        <TextBlock Grid.Row="8" Grid.Column="0" Text="Ремонтное, В:" Style="{StaticResource ColLabel}"/>
                                        <TextBox Grid.Row="8" Grid.Column="1" Text="{Binding RepairLightingVoltage, UpdateSourceTrigger=LostFocus}" IsEnabled="{Binding IsLightingControlEnabled}"/>
                                        <CheckBox Grid.Row="9" Grid.Column="1" Content="Наружное освещение" IsChecked="{Binding OutdoorLightingEnabled}" IsEnabled="{Binding IsLightingControlEnabled}" Margin="0,4,0,0"/>
                                        <StackPanel Grid.Row="10" Grid.Column="1" Orientation="Vertical">
                                            <ComboBox ItemsSource="{Binding PhotoRelayModels}" SelectedItem="{Binding PhotoRelayModel}" ToolTip="Фотореле" IsEnabled="{Binding IsLightingControlEnabled}" Margin="0,2"/>
                                            <ComboBox ItemsSource="{Binding AstroTimerModels}" SelectedItem="{Binding AstroTimerModel}" ToolTip="Астротаймер" IsEnabled="{Binding IsLightingControlEnabled}" Margin="0,2"/>
                                            <ComboBox ItemsSource="{Binding TimeRelayModels}" SelectedItem="{Binding TimeRelayModel}" ToolTip="Реле времени" IsEnabled="{Binding IsLightingControlEnabled}" Margin="0,2"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </materialDesign:Card>

                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="8,0,0,0">
                            <materialDesign:Card Style="{StaticResource GroupCard}" Visibility="{Binding HasAuxiliaryCabinet, Converter={StaticResource BoolToVisibility}}">
                                <StackPanel>
                                    <TextBlock Text="Розетка, обогрев, вентиляция" Style="{StaticResource SectionHeader}"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/><ColumnDefinition Width="90"/></Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                                        <CheckBox Grid.Row="0" Grid.Column="0" Content="Розетка" IsChecked="{Binding SocketEnabled}" IsEnabled="{Binding HasAuxiliaryCabinet}"/>
                                        <ComboBox Grid.Row="0" Grid.Column="1" ItemsSource="{Binding SocketBreakerModels}" SelectedItem="{Binding SocketBreakerModel}" IsEnabled="{Binding SocketEnabled}" ToolTip="Автомат розетки"/>
                                        <ComboBox Grid.Row="0" Grid.Column="2" ItemsSource="{Binding SocketBreakerNominals}" SelectedItem="{Binding SocketBreakerNominal}" ItemTemplate="{StaticResource AmpereItemTemplate}" IsEnabled="{Binding SocketEnabled}"/>
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Модель розетки:" Style="{StaticResource ColLabel}"/>
                                        <ComboBox Grid.Row="1" Grid.Column="1" ItemsSource="{Binding SocketModels}" SelectedItem="{Binding SocketModel}" IsEnabled="{Binding SocketEnabled}"/>
                                        <TextBox Grid.Row="1" Grid.Column="2" Text="{Binding SocketQuantity, UpdateSourceTrigger=LostFocus}" IsEnabled="{Binding SocketEnabled}" ToolTip="Количество"/>

                                        <CheckBox Grid.Row="2" Grid.Column="0" Content="Обогрев" IsChecked="{Binding HeatingEnabled}" IsEnabled="{Binding HasAuxiliaryCabinet}"/>
                                        <ComboBox Grid.Row="2" Grid.Column="1" ItemsSource="{Binding HeatingBreakerModels}" SelectedItem="{Binding HeatingBreakerModel}" IsEnabled="{Binding HeatingEnabled}" ToolTip="Автомат обогрева"/>
                                        <ComboBox Grid.Row="2" Grid.Column="2" ItemsSource="{Binding HeatingBreakerNominals}" SelectedItem="{Binding HeatingBreakerNominal}" ItemTemplate="{StaticResource AmpereItemTemplate}" IsEnabled="{Binding HeatingEnabled}"/>
                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Обогрев/термостат:" Style="{StaticResource ColLabel}"/>
                                        <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Vertical">
                                            <ComboBox ItemsSource="{Binding HeaterModels}" SelectedItem="{Binding HeaterModel}" IsEnabled="{Binding HeatingEnabled}" Margin="0,2"/>
                                            <ComboBox ItemsSource="{Binding ThermostatModels}" SelectedItem="{Binding ThermostatModel}" IsEnabled="{Binding HeatingEnabled}" Margin="0,2"/>
                                        </StackPanel>
                                        <TextBox Grid.Row="3" Grid.Column="2" Text="{Binding HeaterQuantity, UpdateSourceTrigger=LostFocus}" IsEnabled="{Binding HeatingEnabled}" ToolTip="Количество"/>

                                        <CheckBox Grid.Row="4" Grid.Column="0" Content="Вентиляция" IsChecked="{Binding VentilationEnabled}" IsEnabled="{Binding HasAuxiliaryCabinet}"/>
                                        <ComboBox Grid.Row="4" Grid.Column="1" ItemsSource="{Binding VentilationBreakerModels}" SelectedItem="{Binding VentilationBreakerModel}" IsEnabled="{Binding VentilationEnabled}" ToolTip="Автомат вентиляции"/>
                                        <ComboBox Grid.Row="4" Grid.Column="2" ItemsSource="{Binding VentilationBreakerNominals}" SelectedItem="{Binding VentilationBreakerNominal}" ItemTemplate="{StaticResource AmpereItemTemplate}" IsEnabled="{Binding VentilationEnabled}"/>
                                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Вентилятор:" Style="{StaticResource ColLabel}"/>
                                        <ComboBox Grid.Row="5" Grid.Column="1" ItemsSource="{Binding FanModels}" SelectedItem="{Binding FanModel}" IsEnabled="{Binding VentilationEnabled}"/>
                                        <TextBox Grid.Row="5" Grid.Column="2" Text="{Binding FanQuantity, UpdateSourceTrigger=LostFocus}" IsEnabled="{Binding VentilationEnabled}" ToolTip="Количество"/>

                                        <CheckBox Grid.Row="6" Grid.Column="0" Content="ОПС" IsChecked="{Binding OpsEnabled}" IsEnabled="{Binding HasAuxiliaryCabinet}"/>
                                        <StackPanel Grid.Row="6" Grid.Column="1" Orientation="Horizontal">
                                            <ComboBox Width="150" ItemsSource="{Binding OpsTypes}" SelectedItem="{Binding OpsType}" IsEnabled="{Binding OpsEnabled}" Margin="0,2,6,2"/>
                                            <ComboBox Width="150" ItemsSource="{Binding OpsManufacturers}" SelectedItem="{Binding OpsManufacturer}" IsEnabled="{Binding OpsEnabled}" Margin="0,2,0,2"/>
                                        </StackPanel>
                                        <TextBox Grid.Row="6" Grid.Column="2" Text="{Binding OpsLoops, UpdateSourceTrigger=LostFocus}" IsEnabled="{Binding OpsEnabled}" ToolTip="Шлейфы"/>
                                        <TextBlock Grid.Row="7" Grid.Column="0" Text="Модель ОПС:" Style="{StaticResource ColLabel}"/>
                                        <ComboBox Grid.Row="7" Grid.Column="1" Grid.ColumnSpan="2" ItemsSource="{Binding OpsModels}" SelectedItem="{Binding OpsModel}" IsEnabled="{Binding OpsEnabled}"/>
                                        <CheckBox Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="3" Content="Обогрев счетчиков" IsChecked="{Binding MeterHeatingEnabled}" IsEnabled="{Binding HeatingEnabled}" Margin="0,6,0,0"/>
                                    </Grid>
                                </StackPanel>
                            </materialDesign:Card>

                            <materialDesign:Card Style="{StaticResource GroupCard}" Visibility="{Binding HasAuxiliaryCabinet, Converter={StaticResource BoolToVisibility}}">
                                <StackPanel>
                                    <TextBlock Text="РИСЭ" Style="{StaticResource SectionHeader}"/>
                                    <CheckBox Content="Резервный источник электроснабжения" IsChecked="{Binding HasRise}" IsEnabled="{Binding HasAuxiliaryCabinet}"/>
                                    <Grid Margin="0,6,0,0">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="180"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Тип РИСЭ:" Style="{StaticResource ColLabel}"/>
                                        <ComboBox Grid.Row="0" Grid.Column="1" ItemsSource="{Binding RiseTypeOptions}" SelectedItem="{Binding RiseType}" IsEnabled="{Binding HasRise}"/>
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Питание:" Style="{StaticResource ColLabel}"/>
                                        <ComboBox Grid.Row="1" Grid.Column="1" ItemsSource="{Binding RieseSupplySources}" SelectedItem="{Binding RieseSupply}" IsEnabled="{Binding HasRise}"/>
                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Резервируемые цепи:" Style="{StaticResource ColLabel}"/>
                                        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding RieseProtectedCircuits, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding HasRise}"/>
                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Мощность, ВА:" Style="{StaticResource ColLabel}"/>
                                        <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding RiesePowerVa, UpdateSourceTrigger=LostFocus}" IsEnabled="{Binding HasRise}"/>
                                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Автономия, мин:" Style="{StaticResource ColLabel}"/>
                                        <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding RieseAutonomyMinutes, UpdateSourceTrigger=LostFocus}" IsEnabled="{Binding HasRise}"/>
                                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Защитный аппарат:" Style="{StaticResource ColLabel}"/>
                                        <StackPanel Grid.Row="5" Grid.Column="1" Orientation="Horizontal">
                                            <ComboBox Width="150" ItemsSource="{Binding AuxBreakerManufacturers}" SelectedItem="{Binding RieseProtectionManufacturer}" IsEnabled="{Binding HasRise}" Margin="0,0,6,0"/>
                                            <ComboBox Width="220" ItemsSource="{Binding RieseProtectionModels}" SelectedItem="{Binding RieseProtectionModel}" IsEnabled="{Binding HasRise}"/>
                                        </StackPanel>
                                        <TextBlock Grid.Row="6" Grid.Column="0" Text="Модуль РИСЭ:" Style="{StaticResource ColLabel}"/>
                                        <ComboBox Grid.Row="6" Grid.Column="1" ItemsSource="{Binding RieseModuleModels}" SelectedItem="{Binding RieseModuleModel}" IsEnabled="{Binding HasRise}"/>
                                    </Grid>
                                    <TextBox Text="{Binding AuxNotes, UpdateSourceTrigger=PropertyChanged}" MinHeight="48" TextWrapping="Wrap" Margin="0,8,0,0" ToolTip="Примечание по собственным нуждам"/>
                                </StackPanel>
                            </materialDesign:Card>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <!-- ===== PRODUCT CONFIGURATION ===== -->
            <TabItem Visibility="{Binding ShowProductConfigurationTab, Converter={StaticResource BoolToVisibility}}">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <Border Width="12" Height="12" CornerRadius="6" Background="{Binding ProductTabStatusColor, Converter={StaticResource StrBrush}}" BorderBrush="White" BorderThickness="1" Margin="0,0,7,0" ToolTip="{Binding ProductTabStatusText}"/>
                        <TextBlock Text="5. Конфигурация" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Padding="6">
                    <StackPanel MinWidth="1040">
                        <TextBlock Text="{Binding ProductConfigurationHeader}" FontSize="20" FontWeight="SemiBold" Margin="4,0,0,12"/>

                        <materialDesign:Card Style="{StaticResource GroupCard}" Visibility="{Binding ShowDoubleKtpnConfiguration, Converter={StaticResource BoolToVisibility}}">
                            <StackPanel>
                                <TextBlock Text="Трансформаторы, секции и АВР" Style="{StaticResource SectionHeader}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="230"/><ColumnDefinition Width="260"/><ColumnDefinition Width="230"/><ColumnDefinition Width="260"/></Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Т1, производитель:" Style="{StaticResource ColLabel}"/><ComboBox Grid.Row="0" Grid.Column="1" ItemsSource="{Binding Manufacturers}" SelectedItem="{Binding Manufacturer}"/>
                                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Т1, марка:" Style="{StaticResource ColLabel}"/><ComboBox Grid.Row="0" Grid.Column="3" ItemsSource="{Binding Marks}" SelectedItem="{Binding Mark}"/>
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Т2, производитель:" Style="{StaticResource ColLabel}"/><ComboBox Grid.Row="1" Grid.Column="1" ItemsSource="{Binding Manufacturers}" SelectedItem="{Binding SecondTransformerManufacturer}"/>
                                    <TextBlock Grid.Row="1" Grid.Column="2" Text="Т2, марка:" Style="{StaticResource ColLabel}"/><ComboBox Grid.Row="1" Grid.Column="3" ItemsSource="{Binding SecondTransformerMarks}" SelectedItem="{Binding SecondTransformerMark}"/>
